{
  "rewrites": [
    {
      "source": "/((?!api/|src/|node_modules/|@vite/|@react-refresh|@id/|@fs/|sw\\.js|registerSW\\.js|workbox-|manifest\\.webmanifest|.*\\.(?:js|ts|tsx|jsx|css|png|jpg|jpeg|svg|ico|webmanifest|woff|woff2|map)).*)",
